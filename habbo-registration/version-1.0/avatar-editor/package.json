{
  "name": "habbo-registration-v1",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "extract": "node scripts/extract-assets.ts",
    "optimize": "node scripts/optimize-assets.ts",
    "extract-and-optimize": "npm run extract && npm run optimize",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:dev": "NODE_ENV=development tsc --noEmit && vite build --mode development",
    "lint": "eslint src/",
    "preview": "cd demo && npm run preview",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@xmldom/xmldom": "^0.8.11",
    "eslint": "^9.28.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.0-beta",
    "typescript-eslint": "^8.34.0",
    "vite": "^7.3.1",
    "vite-plugin-compression2": "^2.5.0",
    "vite-plugin-eslint2": "^5.0.4",
    "vite-plugin-solid": "^2.11.6",
    "vitest": "^4.0.18",
    "vitest-browser-solid": "^1.0.0"
  },
  "dependencies": {
    "@solid-primitives/trigger": "^1.2.3",
    "comlink": "^4.4.2",
    "libdepixelize-wasm": "^0.2.3",
    "solid-js": "^1.9.11"
  }
}
